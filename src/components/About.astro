---
/**
 * About — "A Leader of Leaders." Bio + vertical timeline + Hinkle pull-quote.
 * Positioning: he doesn't just run — he built the bench and wrote the playbook.
 * Facts sourced from the campaign brief; ALL biographical copy is draft.
 */
import Triquetra from './Triquetra.astro';
import CelticTexture from './CelticTexture.astro';

// Photo rail — real photos, chronological. object-position keeps faces framed
// inside the 3:4 tile crop. Captions are draft — verify wording with candidate.
const photos = [
  {
    src: '/assets/about-2012.jpg',
    w: 900, h: 601,
    pos: '55% 40%',
    alt: 'Black-and-white photo of a young Michael Pickens in a suit, 2012',
    caption: '2012 · Where the work began',
  },
  {
    src: '/assets/about-2016.jpg',
    w: 2048, h: 1462,
    pos: '42% 30%',
    alt: 'Michael Pickens speaking at a podium in front of a Washington Libertarian Party banner, 2016',
    caption: '2016 · Leading the LPWA',
  },
  {
    src: '/assets/about-2018.jpg',
    w: 2048, h: 1365,
    pos: '48% 30%',
    alt: 'Michael Pickens speaking on stage wearing a speaker badge, 2018',
    caption: '2018 · On the speaker circuit',
  },
  {
    src: '/assets/about-2019.jpg',
    w: 2048, h: 1365,
    pos: '28% 40%',
    alt: 'Professional portrait of Michael Pickens in a brown blazer and plaid shirt, 2019',
    caption: '2019 · Building the Academy',
  },
  {
    src: '/assets/about-deeohgee.jpg',
    w: 1152, h: 2048,
    pos: '50% 25%',
    alt: 'Michael Pickens on the livestream couch with his dog Dee Oh Gee, who is wearing a headset',
    caption: 'Today · Live, weekdays — with co-host Dee Oh Gee',
  },
];

const timeline = [
  { year: '2011', label: 'Enters Libertarian Party leadership' },
  { year: '2014', label: 'Elected Chair, Libertarian Party of Washington' },
  { year: '—', label: 'Publishes “Libertarian Leadership: Planting the Seed for a Libertarian Future”' },
  { year: '—', label: 'Founds the Libertarian Leadership Academy (LibertarianLeadership.org)' },
  { year: '—', label: 'Candidate-training work featured by the national Libertarian Party' },
  { year: '2017–20', label: 'Founds Cannasales Inc. — cannabis-industry brand development: marketing, training, event staff & wholesale' },
  { year: '2021–', label: 'Moves into holistic product manufacturing & retail, expanding into canine wellness products and cancer support guides' },
  { year: '—', label: 'Featured in an on-camera interview with Jack Canfield (Chicken Soup for the Soul®)' },
  { year: 'Daily', label: 'Hosts a weekday livestream showcasing Libertarian candidates nationwide' },
  { year: '—', label: 'Publishes “The Liberated Mind”' },
  { year: 'Today', label: 'Current Chair, Libertarian Party of Washington' },
  { year: '2028', label: 'Runs for Pacific County Commissioner', highlight: true },
];
---

<section class="section section--driftwood about" id="about" aria-labelledby="about-title">
  <CelticTexture stroke="rgba(122,94,27,0.07)" />
  <div class="container about__grid">
    <div class="about__intro">
      <Triquetra class="about__knot" size={38} stroke="var(--gold)" />
      <p class="eyebrow">A Leader of Leaders</p>
      <h2 class="section-title" id="about-title">He built the bench. He wrote the manual.</h2>

      <!-- DRAFT COPY — verify with candidate -->
      <div class="about__prose">
        <p>
          For fifteen years, <strong>C. Michael Pickens</strong> has done the
          quiet, unglamorous work that actually wins elections: recruiting
          candidates, training them, and building the local organizations that
          keep communities represented. He is the author of two books on
          practical political leadership and the founder of the Libertarian
          Leadership Academy, an online program that has taught candidates across
          the country how to run disciplined, honest, winning campaigns.
        </p>
        <p>
          His leadership record runs deep and local: Chair of the Libertarian
          Party of Washington, former Vice-Chair of the Libertarian Party of
          California, and former Chair of the Spokane County Libertarians. Along
          the way he has coached candidates to record-breaking vote totals and
          local election wins — work the national Libertarian Party has pointed to
          as a model for candidate recruitment and training.
        </p>
        <p>
          His experience isn't only political. From 2017 to 2020 he founded and
          ran <strong>Cannasales Inc.</strong>, a brand-development agency —
          marketing, training, event staffing, and wholesale under one roof —
          making him a genuine veteran of the cannabis industry's formative years.
          Since 2021 he has worked in holistic product manufacturing and retail —
          a line of work that has grown to include canine wellness products and
          cancer support guides for dogs and their families. He knows firsthand
          what it takes to start a business, meet a payroll, and navigate
          regulation from the inside.
        </p>
        <p>
          Pacific County wouldn't be electing someone learning the job on the way
          in. It would be electing the person who spent fifteen years building the
          bench and writing the playbook — now ready to put that experience to
          work for the bay, the beaches, and the people who call this coast home.
        </p>
        <p class="about__proof">
          And he still shows up every day for the movement: Michael hosts a
          weekday livestream showcasing Libertarian candidates from across the
          country — the leader-of-leaders philosophy in action.
        </p>
      </div>

      <!-- DRAFT COPY — verify with candidate. Endorsement of the BOOK, not the campaign. -->
      <figure class="pull-quote">
        <blockquote>
          A clear, practical guide for anyone serious about building a liberty
          movement that actually wins.
        </blockquote>
        <figcaption>
          — Mark Hinkle, <span>Libertarian Party National Chair, 2010–2012</span>
          <span class="pull-quote__note">(print endorsement of <em>Libertarian Leadership</em>; endorsement of the book, not the 2028 campaign)</span>
        </figcaption>
      </figure>

      <!-- Photo rail — real photos, 2012 → today.
           DRAFT COPY — verify caption wording with candidate. -->
      <div class="about__photos">
        {photos.map((p) => (
          <figure class="about-photo">
            <img
              src={p.src}
              width={p.w}
              height={p.h}
              alt={p.alt}
              loading="lazy"
              style={`object-position: ${p.pos}`}
            />
            <figcaption>{p.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>

    <div class="about__timeline" id="leadership">
      <h3 class="about__timeline-title">Fifteen Years of Building Leaders</h3>
      <ol class="timeline">
        {timeline.map((t) => (
          <li class={`timeline__item${t.highlight ? ' timeline__item--now' : ''}`}>
            <span class="timeline__year">{t.year}</span>
            <span class="timeline__label">{t.label}</span>
          </li>
        ))}
      </ol>
      <p class="about__timeline-note">
        <!-- DRAFT COPY — confirm exact years/titles with candidate before launch -->
        Some dates are approximate and awaiting confirmation.
      </p>
    </div>
  </div>
</section>

<style>
  .about {
    position: relative;
    overflow: hidden;
  }
  .about > .container {
    position: relative;
    z-index: 1;
  }
  .about__knot {
    display: block;
    margin-bottom: 0.9rem;
    opacity: 0.85;
  }

  .about__grid {
    display: grid;
    gap: clamp(2.5rem, 1rem + 6vw, 4.5rem);
    align-items: start;
  }
  .about__proof {
    margin-top: 1.1rem;
    max-width: 60ch;
    padding-left: 1rem;
    border-left: 2px solid var(--gold);
    color: var(--ink);
  }
  .about__prose p { margin-top: 1.1rem; max-width: 60ch; }
  .about__prose strong { color: var(--tide-deep); }

  .pull-quote {
    margin: 2.2rem 0 0;
    padding: 1.5rem 1.6rem;
    background: var(--tide-deep);
    color: var(--fog);
    border-left: 4px solid var(--gold);
    border-radius: var(--radius);
  }
  .pull-quote blockquote {
    font-family: var(--font-display);
    font-size: var(--step-1);
    line-height: 1.3;
    font-style: italic;
  }
  .pull-quote figcaption {
    margin-top: 1rem;
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.74rem;
    color: var(--driftwood);
    line-height: 1.6;
  }
  .pull-quote figcaption span { display: block; text-transform: none; letter-spacing: 0; }
  .pull-quote__note { font-size: 0.72rem; opacity: 0.75; margin-top: 0.3rem; }

  .about__photos {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.9rem;
    margin-top: 2.2rem;
  }
  .about-photo { margin: 0; }
  .about-photo img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid var(--driftwood);
    box-shadow: 0 10px 26px -20px rgba(13, 43, 48, 0.6);
  }
  .about-photo figcaption {
    margin-top: 0.45rem;
    font-size: var(--step--1);
    color: var(--ink-soft);
    line-height: 1.35;
  }

  .about__timeline-title {
    font-size: var(--step-1);
    margin-bottom: 1.3rem;
  }
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0 0 0 0.4rem;
    border-left: 2px solid var(--driftwood);
  }
  .timeline__item {
    position: relative;
    padding: 0 0 1.35rem 1.5rem;
  }
  .timeline__item::before {
    content: '';
    position: absolute;
    left: calc(-0.4rem - 6px);
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--salmon-copper);
    border: 2px solid var(--fog-2);
  }
  .timeline__item--now::before {
    background: var(--gold);
    box-shadow: 0 0 0 4px rgba(193, 149, 63, 0.22);
  }
  .timeline__year {
    display: block;
    font-family: var(--font-util);
    font-weight: 700;
    letter-spacing: 0.06em;
    font-size: 0.8rem;
    color: var(--gold-deep);
  }
  .timeline__label { display: block; color: var(--ink); font-size: var(--step-0); }
  .timeline__item--now .timeline__label { font-weight: 600; }
  .about__timeline-note {
    margin-top: 0.6rem;
    font-size: var(--step--1);
    color: var(--ink-soft);
    font-style: italic;
  }

  @media (min-width: 620px) {
    .about__photos { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 940px) {
    .about__grid { grid-template-columns: 1.25fr 0.75fr; }
    .about__photos { grid-template-columns: repeat(5, 1fr); }
  }
</style>
