---
/**
 * Books — two book cards with placeholder covers and outbound purchase-link
 * placeholders (href="#" data-todo="amazon-link").
 */
const books = [
  {
    cover: '/assets/book-libertarian-leadership.svg',
    title: 'Libertarian Leadership',
    subtitle: 'Planting the Seed for a Libertarian Future',
    // DRAFT COPY — verify with candidate
    blurb:
      'The field manual for building a liberty movement that wins — recruiting candidates, running disciplined campaigns, and growing local organizations that last. Endorsed in print by Mark Hinkle (LP National Chair, 2010–2012) and Judge Jim Gray (2012 LP Vice-Presidential nominee).',
  },
  {
    cover: '/assets/book-liberated-mind.svg',
    title: 'The Liberated Mind',
    // DRAFT COPY — verify with candidate (subtitle + blurb inferred; confirm actual description)
    subtitle: 'On intellectual freedom and self-ownership',
    blurb:
      'A reflective look at what it means to think for yourself — how a mind freed from fear, conformity, and dependence becomes the foundation for a freer life and a freer society.',
  },
];
---

<section class="section books" id="books" aria-labelledby="books-title">
  <div class="container">
    <p class="eyebrow">He Wrote the Playbook</p>
    <h2 class="section-title" id="books-title">Books</h2>
    <p class="lede">
      Two books on how liberty-minded candidates actually win — the same
      strategies Michael has used to train winners across the country.
    </p>

    <div class="books__grid">
      {books.map((b) => (
        <article class="book-card">
          <div class="book-card__cover">
            <img
              src={b.cover}
              width="600"
              height="900"
              alt={`Book cover: ${b.title}`}
              loading="lazy"
            />
          </div>
          <div class="book-card__body">
            <h3 class="book-card__title">{b.title}</h3>
            <p class="book-card__subtitle">{b.subtitle}</p>
            <p class="book-card__blurb">{b.blurb}</p>
            <a class="btn btn--outline-ink" href="#" data-todo="amazon-link">
              Get the Book
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .books__grid {
    margin-top: 2.5rem;
    display: grid;
    gap: 1.75rem;
    grid-template-columns: 1fr;
  }
  .book-card {
    display: grid;
    gap: 1.4rem;
    align-items: start;
    background: #fff;
    border: 1px solid var(--driftwood);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    box-shadow: 0 10px 30px -24px rgba(13, 43, 48, 0.6);
  }
  .book-card__cover img {
    width: 100%;
    max-width: 220px;
    height: auto;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-inline: auto;
  }
  .book-card__title { font-size: var(--step-2); }
  .book-card__subtitle {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.75rem;
    color: var(--salmon-copper);
    margin: 0.35rem 0 0.9rem;
    font-weight: 600;
  }
  .book-card__blurb { color: var(--ink-soft); margin-bottom: 1.3rem; }

  @media (min-width: 620px) {
    .book-card { grid-template-columns: 200px 1fr; }
    .book-card__cover img { margin-inline: 0; }
  }
  @media (min-width: 1000px) {
    .books__grid { grid-template-columns: repeat(2, 1fr); }
    .book-card { grid-template-columns: 1fr; }
    .book-card__cover img { margin-inline: auto; }
  }
</style>
