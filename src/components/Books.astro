---
/**
 * Books — deliberately compact. The books earn a mention, not a billboard:
 * small covers, one line each, text links out to purchase pages.
 */
const books = [
  {
    cover: '/assets/book-libertarian-leadership.jpg',
    w: 311, h: 466,
    title: 'Libertarian Leadership',
    // DRAFT COPY — verify with Michael
    line: 'Planting the Seed for a Libertarian Future (2012) — endorsed by Mark Hinkle & Judge Jim Gray.',
    href: 'https://www.amazon.com/Libertarian-Leadership-Planting-Seed-Future/dp/0983963525',
  },
  {
    cover: '/assets/book-liberated-mind.jpg',
    w: 342, h: 342,
    title: 'The Liberated Mind',
    line: 'Rewire Your Mind. Reclaim Your Power. Rewrite Your Life.',
    href: 'https://www.amazon.com/Liberated-Mind-Rewire-Reclaim-Rewrite/dp/B0FFJ1XRYJ',
  },
];
---

<section class="section books" id="books" aria-labelledby="books-title">
  <div class="container">
    <div class="books__row">
      <div class="books__heading">
        <p class="eyebrow">Also an Author</p>
        <h2 class="books__title" id="books-title">Books by Michael</h2>
      </div>

      <ul class="books__list">
        {books.map((b) => (
          <li class="book">
            <img
              class="book__cover"
              src={b.cover}
              width={b.w}
              height={b.h}
              alt={`Book cover: ${b.title}`}
              loading="lazy"
            />
            <div class="book__text">
              <h3 class="book__name">{b.title}</h3>
              <p class="book__line">{b.line}</p>
              <a class="book__link" href={b.href} target="_blank" rel="noopener noreferrer">Get the book →</a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  /* Compact section: roughly half the vertical rhythm of a standard section */
  .books { padding-block: clamp(1.8rem, 1.4rem + 2vw, 3rem); }

  .books__row {
    display: grid;
    gap: 1.5rem;
    align-items: center;
  }
  .books__title {
    font-size: var(--step-1);
    margin-top: 0.35rem;
  }

  .books__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.1rem;
  }
  .book {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .book__cover {
    flex: none;
    /* Height-locked so square (audiobook) and 2:3 covers sit level and show whole */
    height: 96px;
    width: auto;
    max-width: 96px;
    border-radius: 3px;
    box-shadow: 0 8px 18px -12px rgba(13, 43, 48, 0.6);
    border: 1px solid var(--driftwood);
  }
  .book__name {
    font-size: var(--step-0);
    margin: 0;
  }
  .book__line {
    margin: 0.2rem 0 0.3rem;
    font-size: var(--step--1);
    color: var(--ink-soft);
    max-width: 46ch;
  }
  .book__link {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--gold-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--gold);
    padding-bottom: 1px;
  }
  .book__link:hover { color: var(--tide-deep); border-color: var(--tide-deep); }

  @media (min-width: 780px) {
    .books__row { grid-template-columns: auto 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); }
    .books__list { grid-template-columns: repeat(2, 1fr); }
  }
</style>
