---
// Brand story: the craft behind BE Canine, set like a field-guide spread.
const plates = [
  {
    numeral: 'I.',
    title: 'Formulated by a canine nutritionist',
    note: 'Every formula designed for dogs from the first ingredient to the last.',
  },
  {
    numeral: 'II.',
    title: 'Small batches, always fresh',
    note: 'Made in limited runs so what reaches your dog is at its peak.',
  },
  {
    numeral: 'III.',
    title: 'Third-party tested, every batch',
    note: 'Independently verified for purity before it ever ships.',
  },
];
---

<section id="story" class="story section">
  <div class="container">
    <div class="story-grid" data-reveal>
      <div class="story-text">
        <span class="eyebrow">why be canine</span>
        <h2>Nutrition Your Dog Can Feel</h2>
        <p>
          Great nutrition shows up in the everyday things: steady energy on the
          morning walk, comfortable digestion, a coat that shines, joints that
          keep up with the zoomies. BE Canine is built for exactly that — seven
          targeted formulas covering gut, immune system, joints, skin and paws,
          digestion, hydration, and daily foundations, so you can support the
          dog in front of you.
        </p>
        <p>
          What makes us different is how seriously we take what goes in the
          bowl. Every formula is designed by a canine nutritionist from
          whole-food ingredients — no fillers, no artificial preservatives, no
          by-products. We make each formula in small batches for freshness, and
          every single batch is third-party tested for purity before it
          reaches your dog.
        </p>
        <p>
          BE Canine is the canine line of Botanical Enlightenment, and it
          carries the same standard of craftsmanship: careful sourcing,
          meticulous records, and a refusal to cut corners. Heritage is our
          character — your dog's best years are the point.
        </p>
      </div>

      <figure class="story-figure">
        <blockquote>
          <p>
            &ldquo;Whole ingredients. Small batches. Tested, every time. That
            is the whole recipe.&rdquo;
          </p>
          <cite>— our promise, Botanical Enlightenment</cite>
        </blockquote>
        <figcaption class="visually-hidden">
          The three commitments behind every BE Canine formula
        </figcaption>
        <ol class="plates" role="list">
          {plates.map(({ numeral, title, note }) => (
            <li>
              <span class="plate-numeral" aria-hidden="true">{numeral}</span>
              <span class="plate-body">
                <strong>{title}</strong>
                <span class="plate-note">{note}</span>
              </span>
            </li>
          ))}
        </ol>
      </figure>
    </div>
  </div>
</section>

<style>
  .story {
    background: var(--parchment-deep);
    border-block: 1px solid var(--rule);
  }

  .story-grid {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }

  .story h2 {
    font-size: var(--text-2xl);
  }

  .story-text p {
    color: var(--ink-soft);
    max-width: 60ch;
  }

  .story-figure {
    margin: 0;
    padding: clamp(1.5rem, 3vw, 2.2rem);
    border: 1px solid var(--rule-strong);
    outline: 1px solid var(--rule);
    outline-offset: 5px;
    background: var(--parchment);
    box-shadow: var(--paper-shadow);
  }

  .story-figure blockquote {
    margin: 0 0 1.6rem;
    padding: 0;
  }

  .story-figure blockquote p {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: 1.4;
    margin-bottom: 0.5em;
  }

  .story-figure cite {
    font-style: normal;
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    letter-spacing: 0.14em;
    color: var(--copper);
  }

  .plates {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid var(--rule);
  }

  .plates li {
    display: flex;
    gap: 0.9rem;
    padding-block: 0.9rem;
    border-bottom: 1px solid var(--rule);
  }

  .plate-numeral {
    font-family: var(--font-display);
    color: var(--copper);
    min-width: 2rem;
  }

  .plate-body {
    display: block;
  }

  .plate-body strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: var(--text-base);
  }

  .plate-note {
    display: block;
    font-size: var(--text-sm);
    color: var(--ink-soft);
  }

  @media (min-width: 56rem) {
    .story-grid {
      grid-template-columns: minmax(0, 1.15fr) minmax(0, 0.85fr);
    }
  }
</style>
