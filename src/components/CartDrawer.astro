---
// Slide-in cart drawer ("Your Satchel"). Markup only — all state, line-item
// rendering, and open/close behavior live in src/scripts/cart.js, which
// targets #cart-drawer, [data-cart-items], [data-cart-subtotal], and the
// [data-cart-close]/[data-checkout] controls below.
// Starts hidden + inert; cart.js flips aria-hidden/inert with .is-open.
---

<div id="cart-drawer" aria-hidden="true" inert>
  <div class="cart-overlay" data-cart-close></div>

  <aside
    class="cart-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="cart-title"
    tabindex="-1"
  >
    <header class="cart-header">
      <h2 class="cart-title" id="cart-title">Your Satchel</h2>
      <button type="button" class="cart-close" data-cart-close aria-label="Close cart">
        &#10005;
      </button>
    </header>

    <!-- cart.js fills this with line items (or the empty state) -->
    <ul class="cart-items" data-cart-items></ul>

    <footer class="cart-footer">
      <div class="cart-subtotal-row">
        <span class="cart-subtotal-label">Subtotal</span>
        <span class="cart-subtotal" data-cart-subtotal aria-live="polite">$0.00</span>
      </div>
      <p class="cart-note">Shipping &amp; taxes calculated at checkout.</p>
      <button type="button" class="btn btn-primary cart-checkout" data-checkout disabled>
        Checkout &mdash; Coming Soon
      </button>
      <button type="button" class="cart-continue" data-cart-close>
        or continue browsing
      </button>
    </footer>
  </aside>
</div>

<!-- Global styles: cart.js injects line items at runtime, so these rules
     must not be scoped. Everything is namespaced under #cart-drawer. -->
<style is:global>
  /* Header badge: hidden until cart.js marks it as holding items. */
  [data-cart-count]:not(.has-items) {
    display: none !important;
  }

  #cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 200;
    pointer-events: none;
  }

  #cart-drawer .cart-overlay {
    position: absolute;
    inset: 0;
    background: rgba(46, 36, 24, 0.45);
    opacity: 0;
    transition: opacity 240ms ease;
  }

  #cart-drawer .cart-panel {
    position: absolute;
    top: 0;
    right: 0;
    height: 100%;
    width: min(380px, 92vw);
    display: flex;
    flex-direction: column;
    background-color: var(--parchment);
    /* Same faint laid-paper screen as the page ground */
    background-image:
      repeating-linear-gradient(0deg, rgba(46, 36, 24, 0.022) 0 1px, transparent 1px 26px),
      repeating-linear-gradient(90deg, rgba(46, 36, 24, 0.014) 0 1px, transparent 1px 4px);
    border-left: 1px solid var(--rule-strong);
    box-shadow: var(--paper-shadow);
    transform: translateX(102%);
    transition: transform 300ms cubic-bezier(0.33, 1, 0.68, 1);
  }

  #cart-drawer.is-open {
    pointer-events: auto;
  }

  #cart-drawer.is-open .cart-overlay {
    opacity: 1;
  }

  #cart-drawer.is-open .cart-panel {
    transform: none;
  }

  /* ---- Header ---- */
  #cart-drawer .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.35rem 0.95rem;
    border-bottom: 1px solid var(--rule);
  }

  #cart-drawer .cart-title {
    margin: 0;
    font-family: var(--font-display-sc);
    font-weight: 400;
    font-size: var(--text-lg);
    letter-spacing: 0.14em;
    text-transform: lowercase; /* IM Fell English SC renders lowercase as small caps */
    color: var(--ink);
  }

  #cart-drawer .cart-close {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 50%;
    color: var(--ink-soft);
    font-size: 0.85rem;
    line-height: 1;
    transition: color 160ms ease, border-color 160ms ease;
  }

  #cart-drawer .cart-close:hover {
    color: var(--copper);
    border-color: var(--rule-strong);
  }

  /* ---- Items (injected by cart.js) ---- */
  #cart-drawer .cart-items {
    flex: 1;
    overflow-y: auto;
    margin: 0;
    padding: 0.35rem 1.35rem;
    list-style: none;
  }

  #cart-drawer .cart-line {
    display: flex;
    gap: 0.9rem;
    padding: 1.05rem 0;
    border-bottom: 1px solid var(--rule);
  }

  #cart-drawer .cart-line-thumb {
    width: 3.5rem;
    height: 4rem;
    flex: none;
    object-fit: contain;
    background: var(--parchment-deep);
    border: 1px solid var(--rule);
    border-radius: 2px;
    padding: 0.25rem;
  }

  #cart-drawer .cart-line-body {
    flex: 1;
    min-width: 0;
  }

  #cart-drawer .cart-line-name {
    margin: 0 0 0.15rem;
    font-family: var(--font-display);
    font-size: var(--text-base);
    line-height: 1.3;
    color: var(--ink);
  }

  #cart-drawer .cart-line-unit {
    margin: 0 0 0.5rem;
    font-size: var(--text-sm);
    color: var(--copper);
  }

  #cart-drawer .cart-line-each {
    color: var(--ink-soft);
    font-style: italic;
  }

  #cart-drawer .cart-line-qty {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    border: 1px solid var(--rule);
    border-radius: 2px;
  }

  #cart-drawer .cart-qty-btn {
    width: 1.7rem;
    height: 1.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--moss-deep);
    font-size: 1rem;
    line-height: 1;
    transition: background-color 140ms ease;
  }

  #cart-drawer .cart-qty-btn:hover:not([disabled]) {
    background: rgba(63, 82, 49, 0.09);
  }

  #cart-drawer .cart-qty-btn[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }

  #cart-drawer .cart-qty-value {
    min-width: 1.5rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-size: var(--text-sm);
    color: var(--ink);
  }

  #cart-drawer .cart-line-side {
    flex: none;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: space-between;
  }

  /* Small "strike from ledger" ✕ */
  #cart-drawer .cart-line-remove {
    background: transparent;
    border: none;
    padding: 0.1rem 0.2rem;
    color: var(--ink-soft);
    font-size: 0.7rem;
    line-height: 1;
    letter-spacing: 0.05em;
    opacity: 0.75;
    transition: color 140ms ease, opacity 140ms ease;
  }

  #cart-drawer .cart-line-remove:hover {
    color: var(--copper);
    opacity: 1;
    text-decoration: line-through;
  }

  #cart-drawer .cart-line-total {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }

  /* ---- Empty state ---- */
  #cart-drawer .cart-empty {
    padding: 3.5rem 1rem;
    text-align: center;
    color: var(--ink-soft);
  }

  #cart-drawer .cart-empty-flourish {
    display: block;
    margin-bottom: 0.9rem;
    color: var(--copper);
    font-size: 1.3rem;
  }

  #cart-drawer .cart-empty-text {
    margin: 0 0 1.1rem;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--ink);
  }

  #cart-drawer .cart-empty-link {
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--moss);
  }

  /* ---- Footer ---- */
  #cart-drawer .cart-footer {
    padding: 1.1rem 1.35rem 1.35rem;
    border-top: 1px solid var(--rule-strong);
  }

  #cart-drawer .cart-subtotal-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.35rem;
  }

  #cart-drawer .cart-subtotal-label {
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    letter-spacing: 0.22em;
    text-transform: lowercase;
    color: var(--ink-soft);
  }

  #cart-drawer .cart-subtotal {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-variant-numeric: tabular-nums;
    color: var(--copper);
  }

  #cart-drawer .cart-note {
    margin: 0 0 1rem;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--ink-soft);
  }

  #cart-drawer .cart-checkout {
    width: 100%;
  }

  #cart-drawer .cart-continue {
    display: block;
    margin: 0.85rem auto 0;
    background: transparent;
    border: none;
    padding: 0.15rem 0.3rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: var(--rule-strong);
    text-underline-offset: 0.2em;
  }

  #cart-drawer .cart-continue:hover {
    color: var(--moss-deep);
  }

  @media (prefers-reduced-motion: reduce) {
    #cart-drawer .cart-overlay,
    #cart-drawer .cart-panel {
      transition: none;
    }
  }
</style>
