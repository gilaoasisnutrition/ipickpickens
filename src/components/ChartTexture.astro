---
/**
 * ChartTexture — the signature element.
 * A quiet nautical-chart motif evoking Willapa Bay & the Pacific County coast:
 * depth-contour curves, soundings (depth dots), and a channel line. Rendered as
 * low-contrast strokes so it reads as texture behind hero/dark surfaces.
 *
 * Decorative only: aria-hidden and no semantic meaning.
 */
export interface Props {
  class?: string;
  /** Stroke colour; defaults to a faint fog tint suitable for --tide-deep. */
  stroke?: string;
}
const { class: className = '', stroke = 'rgba(237,240,236,0.10)' } = Astro.props;
---

<svg
  class={`chart-texture ${className}`}
  viewBox="0 0 800 600"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <g fill="none" stroke={stroke} stroke-width="1.4">
    <!-- Depth contours: nested, irregular — the shape of a shoaling bay -->
    <path d="M-40 120 C 140 60, 300 150, 430 90 S 720 60, 860 140" />
    <path d="M-40 190 C 150 140, 320 220, 450 160 S 720 150, 860 210" />
    <path d="M-40 265 C 170 210, 330 300, 470 235 S 720 240, 860 300" />
    <path d="M-40 350 C 180 300, 350 380, 500 320 S 730 330, 860 390" />
    <path d="M-40 440 C 200 395, 360 470, 520 410 S 740 430, 860 480" />
    <path d="M-40 530 C 210 490, 380 560, 540 505 S 760 520, 860 560" />
  </g>

  <!-- The channel line — a slightly stronger dashed contour -->
  <path
    d="M-40 300 C 200 250, 360 335, 520 275 S 760 290, 860 340"
    fill="none"
    stroke={stroke}
    stroke-width="1.6"
    stroke-dasharray="2 9"
    opacity="1.4"
  />

  <!-- Soundings: small depth marks scattered across the bay -->
  <g fill={stroke}>
    <circle cx="120" cy="160" r="2" />
    <circle cx="250" cy="235" r="2" />
    <circle cx="360" cy="120" r="2" />
    <circle cx="470" cy="300" r="2" />
    <circle cx="600" cy="200" r="2" />
    <circle cx="690" cy="360" r="2" />
    <circle cx="180" cy="420" r="2" />
    <circle cx="410" cy="470" r="2" />
    <circle cx="560" cy="440" r="2" />
    <circle cx="300" cy="360" r="2" />
  </g>

  <!-- Compass rose ticks, faint, upper-right -->
  <g stroke={stroke} stroke-width="1.2">
    <line x1="700" y1="90" x2="700" y2="150" />
    <line x1="670" y1="120" x2="730" y2="120" />
    <circle cx="700" cy="120" r="22" fill="none" />
  </g>
</svg>

<style>
  .chart-texture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>
