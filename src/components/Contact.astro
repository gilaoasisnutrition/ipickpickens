---
/**
 * Contact — scheduler CTA + message form, wired to the Worker at
 * POST /api/contact (worker/index.js). Every message is stored in the
 * SIGNUPS KV namespace and forwarded to the Libertarian Leadership Academy
 * webhook when CONTACT_WEBHOOK_URL is configured (wrangler.jsonc).
 * Falls back to a normal form POST when JS is unavailable.
 * Turnstile bot check renders only when a site key is set in src/config.ts.
 */
import CelticTexture from './CelticTexture.astro';
import { TURNSTILE_SITE_KEY, SCHEDULER_URL } from '../config';

const interestOptions = [
  'Campaign & leadership coaching',
  'Speaking engagement',
  'Podcast / media appearance',
  'Livestream guest',
  'Just keep me posted',
];
---

<section class="section section--dark on-dark contact" id="contact" aria-labelledby="contact-title">
  <CelticTexture stroke="rgba(216,178,90,0.05)" />
  <div class="container contact__grid">
    <div class="contact__intro">
      <p class="eyebrow">Work With Michael</p>
      <h2 class="section-title" id="contact-title">Let's talk.</h2>
      <p class="lede">
        Coaching, speaking, media, or a conversation about leadership — the
        fastest way to connect is to grab time on Michael's calendar.
      </p>
      <a
        class="btn btn--primary contact__schedule"
        href={SCHEDULER_URL}
        target="_blank"
        rel="noopener noreferrer"
      >
        Schedule with Michael
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <p class="contact__alm">
        Michael's coaching and training work lives at the
        <a href="https://libertarianleadership.org" target="_blank" rel="noopener noreferrer">Libertarian Leadership Academy</a>.
      </p>
    </div>

    <form class="signup" method="post" action="/api/contact" aria-labelledby="contact-title">
      <div class="signup__row">
        <div class="field">
          <label for="contact-name">Name</label>
          <input id="contact-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="contact-email">Email</label>
          <input id="contact-email" name="email" type="email" autocomplete="email" required />
        </div>
      </div>

      <fieldset class="field interest">
        <legend>What's this about?</legend>
        <div class="interest__grid">
          {interestOptions.map((opt) => (
            <label class="checkbox">
              <input type="checkbox" name="interest" value={opt} />
              <span>{opt}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="field">
        <label for="contact-message">Message</label>
        <textarea id="contact-message" name="message" rows="4"></textarea>
      </div>

      {TURNSTILE_SITE_KEY && (
        <div
          class="cf-turnstile"
          data-sitekey={TURNSTILE_SITE_KEY}
          data-theme="dark"
        />
      )}

      <button class="btn btn--primary signup__submit" type="submit">Send Message</button>
      <p class="signup__status" role="status" aria-live="polite" hidden></p>
      <p class="signup__note">
        Your message goes straight to Michael's team. We keep your information
        private — unsubscribe anytime.
      </p>
    </form>
  </div>

  {TURNSTILE_SITE_KEY && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
  )}
</section>

<style>
  .contact {
    position: relative;
    overflow: hidden;
  }
  .contact > .container {
    position: relative;
    z-index: 1;
  }
  .contact__grid {
    display: grid;
    gap: clamp(2rem, 1rem + 4vw, 3.5rem);
    align-items: start;
  }
  .contact__schedule { margin-top: 1.6rem; }
  .contact__alm {
    margin-top: 1.2rem;
    padding: 0.8rem 1rem;
    border-left: 3px solid var(--gold);
    background: var(--tide-deep-2);
    border-radius: var(--radius);
    color: var(--driftwood);
    font-size: var(--step--1);
  }
  .contact__alm a { color: var(--gold-bright); font-weight: 600; }
  .signup__status {
    margin: 0;
    font-weight: 600;
    font-size: var(--step--1);
  }
  .signup__status.is-ok { color: var(--gold-bright); }
  .signup__status.is-err { color: #f2a3a3; }
  .signup {
    background: var(--tide-deep-2);
    border: 1px solid rgba(188, 179, 162, 0.22);
    border-radius: var(--radius-lg);
    padding: clamp(1.4rem, 1rem + 2vw, 2rem);
    display: grid;
    gap: 1.1rem;
  }
  .signup__row {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }
  .field { display: grid; gap: 0.4rem; }
  .field label,
  .interest legend {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--driftwood);
  }
  .field input[type='text'],
  .field input[type='email'],
  .field textarea {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border-radius: var(--radius);
    border: 1px solid var(--driftwood);
    background: var(--fog);
    color: var(--ink);
    font: inherit;
  }
  .field textarea { resize: vertical; }
  .field input:focus-visible,
  .field textarea:focus-visible { outline-color: var(--gold-bright); }

  .interest { border: 0; padding: 0; margin: 0; }
  .interest legend { padding: 0; margin-bottom: 0.6rem; }
  .interest__grid {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: 1fr;
  }
  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fog);
    font-size: 0.95rem;
    cursor: pointer;
  }
  .checkbox input {
    width: 20px;
    height: 20px;
    accent-color: var(--gold-deep);
    flex: none;
  }
  .signup__submit { justify-self: start; margin-top: 0.3rem; }
  .signup__note { font-size: var(--step--1); color: var(--driftwood); margin: 0; }

  @media (min-width: 560px) {
    .signup__row { grid-template-columns: 1fr 1fr; }
    .interest__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 940px) {
    .contact__grid { grid-template-columns: 0.85fr 1.15fr; }
  }
</style>

<script>
  // Progressive enhancement: submit via fetch and show inline status.
  // Without JS the form still POSTs normally; the Worker 303-redirects back
  // with ?contact=thanks, handled below.
  const form = document.querySelector<HTMLFormElement>('.signup');
  const status = document.querySelector<HTMLParagraphElement>('.signup__status');

  const show = (msg: string, ok: boolean) => {
    if (!status) return;
    status.textContent = msg;
    status.classList.toggle('is-ok', ok);
    status.classList.toggle('is-err', !ok);
    status.hidden = false;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.signup__submit');
    if (btn) btn.disabled = true;
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { accept: 'application/json' },
      });
      const data = await res.json().catch(() => ({ ok: false, error: 'Unexpected response.' }));
      if (data.ok) {
        show("Message sent — thank you! We'll be in touch soon.", true);
        form.reset();
      } else {
        show(data.error || 'Something went wrong — please try again.', false);
      }
    } catch {
      show('Network hiccup — please try again in a moment.', false);
    } finally {
      if (btn) btn.disabled = false;
    }
  });

  // No-JS fallback landing: /?contact=thanks#contact
  if (new URLSearchParams(location.search).get('contact') === 'thanks') {
    show("Message sent — thank you! We'll be in touch soon.", true);
  }
</script>
