---
/**
 * DonateWidget — VISUAL-ONLY donation panel.
 *
 * TODO: replace with Give Gold Payments embed.
 * This component is intentionally self-contained and non-functional so it can be
 * swapped out 1:1. When the real processor embed is ready, replace the entire
 * <form class="donate-panel"> block below (or this whole component) with the
 * embed snippet. Nothing else on the page depends on its internals.
 *
 * WA PDC NOTE: contribution limits, employer/occupation collection, and
 * disclaimer requirements must be confirmed before accepting real money.
 */
const presets = [25, 50, 100, 250];
---

<section class="section donate" id="donate" aria-labelledby="donate-title">
  <div class="container">
    <div class="donate__card">
      <div class="donate__intro">
        <p class="eyebrow">Chip In</p>
        <h2 class="section-title" id="donate-title">Fuel the campaign.</h2>
        <p class="lede">
          Grassroots dollars keep this campaign independent and accountable to
          Pacific County — not to anyone else. Every amount helps.
        </p>
        <p class="donate__trust">
          <!-- DRAFT COPY — verify with candidate / committee -->
          Contributions are not tax-deductible. Paid for by the committee named
          below.
        </p>
      </div>

      <!-- data-todo="donate-embed" — replace with Give Gold Payments embed -->
      <form class="donate-panel" data-todo="donate-embed" aria-label="Make a donation">
        <div class="donate-panel__freq" role="group" aria-label="Donation frequency">
          <button type="button" class="freq-btn is-active" data-freq="once" aria-pressed="true">One-time</button>
          <button type="button" class="freq-btn" data-freq="monthly" aria-pressed="false">Monthly</button>
        </div>

        <div class="donate-panel__amounts" role="group" aria-label="Donation amount">
          {presets.map((amt, i) => (
            <button
              type="button"
              class={`amount-btn${i === 1 ? ' is-active' : ''}`}
              data-amount={amt}
              aria-pressed={i === 1 ? 'true' : 'false'}
            >
              ${amt}
            </button>
          ))}
          <div class="amount-custom">
            <span aria-hidden="true">$</span>
            <input
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              placeholder="Custom"
              aria-label="Custom donation amount"
              class="amount-custom__input"
            />
          </div>
        </div>

        <button type="submit" class="btn btn--primary donate-panel__submit">
          Donate <span class="donate-panel__summary" data-summary>$50</span>
        </button>
        <p class="donate-panel__note">
          Placeholder only — no payment is processed. Real processor coming soon.
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .donate__card {
    display: grid;
    gap: clamp(1.8rem, 1rem + 4vw, 3rem);
    align-items: center;
    background: var(--tide-deep);
    color: var(--fog);
    border-radius: var(--radius-lg);
    padding: clamp(1.6rem, 1rem + 3vw, 3rem);
    box-shadow: var(--shadow);
  }
  .donate__intro .lede { color: var(--driftwood); }
  .donate__trust { margin-top: 1rem; font-size: var(--step--1); color: var(--driftwood); }

  .donate-panel {
    background: var(--fog);
    color: var(--ink);
    border-radius: var(--radius-lg);
    padding: clamp(1.3rem, 1rem + 2vw, 1.9rem);
    display: grid;
    gap: 1.1rem;
  }
  .donate-panel__freq {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    background: var(--fog-2);
    border-radius: var(--radius);
    padding: 0.3rem;
  }
  .freq-btn {
    padding: 0.6rem;
    border: 0;
    border-radius: calc(var(--radius) - 1px);
    background: transparent;
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .freq-btn.is-active { background: #fff; color: var(--gold-deep); box-shadow: 0 1px 4px rgba(13,43,48,0.15); }

  .donate-panel__amounts {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }
  .amount-btn {
    padding: 0.85rem;
    border: 2px solid var(--driftwood);
    border-radius: var(--radius);
    background: #fff;
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--tide-deep);
    transition: border-color 0.12s ease, background 0.12s ease, color 0.12s ease;
  }
  .amount-btn:hover { border-color: var(--gold); }
  .amount-btn.is-active { border-color: var(--gold); background: var(--gold); color: var(--tide-deep); }

  .amount-custom {
    grid-column: span 2;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    border: 2px solid var(--driftwood);
    border-radius: var(--radius);
    padding: 0 0.85rem;
    background: #fff;
  }
  .amount-custom span { font-family: var(--font-display); font-size: 1.1rem; color: var(--ink-soft); }
  .amount-custom__input {
    flex: 1;
    border: 0;
    padding: 0.8rem 0;
    font: inherit;
    font-size: 1.1rem;
    background: transparent;
    color: var(--ink);
  }
  .amount-custom:focus-within { border-color: var(--gold); }
  .amount-custom__input:focus-visible { outline: none; }

  .donate-panel__submit { width: 100%; font-size: 0.9rem; }
  .donate-panel__note { text-align: center; font-size: var(--step--1); color: var(--ink-soft); margin: 0; }

  @media (min-width: 860px) {
    .donate__card { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
  // Visual-only interactions for the placeholder donate panel.
  const panel = document.querySelector<HTMLFormElement>('.donate-panel');
  if (panel) {
    const amountBtns = panel.querySelectorAll<HTMLButtonElement>('.amount-btn');
    const customInput = panel.querySelector<HTMLInputElement>('.amount-custom__input');
    const freqBtns = panel.querySelectorAll<HTMLButtonElement>('.freq-btn');
    const summary = panel.querySelector<HTMLElement>('[data-summary]');

    let amount = 50;
    let freq = 'once';

    const render = () => {
      if (summary) {
        summary.textContent = `$${amount}${freq === 'monthly' ? '/mo' : ''}`;
      }
    };

    const selectAmount = (val: number, btn?: HTMLButtonElement) => {
      amount = val;
      amountBtns.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-pressed', String(on));
      });
      render();
    };

    amountBtns.forEach((b) =>
      b.addEventListener('click', () => {
        if (customInput) customInput.value = '';
        selectAmount(Number(b.dataset.amount), b);
      })
    );

    customInput?.addEventListener('input', () => {
      const val = Number(customInput.value);
      amountBtns.forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-pressed', 'false');
      });
      if (val > 0) amount = val;
      render();
    });

    freqBtns.forEach((b) =>
      b.addEventListener('click', () => {
        freq = b.dataset.freq || 'once';
        freqBtns.forEach((x) => {
          const on = x === b;
          x.classList.toggle('is-active', on);
          x.setAttribute('aria-pressed', String(on));
        });
        render();
      })
    );

    // Placeholder: prevent submission — no processor wired yet.
    panel.addEventListener('submit', (e) => {
      e.preventDefault();
      alert('Donations are not live yet — the payment processor is being set up. Thank you for your support!');
    });

    render();
  }
</script>
