---
/**
 * Endorsements — designed "coming soon" state (not an empty void). Placeholder
 * cards read as intentional. Replace with real endorsers as they come in.
 */
const placeholders = [
  'Local business owner',
  'Community leader',
  'Fellow elected official',
  'Longtime resident',
];
---

<section class="section section--driftwood endorsements" id="endorsements" aria-labelledby="endorsements-title">
  <div class="container">
    <p class="eyebrow">In Good Company</p>
    <h2 class="section-title" id="endorsements-title">Endorsements</h2>
    <p class="lede">
      Endorsements are coming in from across Pacific County. Want to add your
      name? <a href="#get-involved">Get in touch.</a>
    </p>

    <!-- data-todo="endorsements" — replace placeholder cards with real endorsers -->
    <ul class="endorsements__grid" data-todo="endorsements">
      {placeholders.map((role) => (
        <li class="endorse-card endorse-card--pending">
          <span class="endorse-card__mark" aria-hidden="true">“”</span>
          <p class="endorse-card__role">{role}</p>
          <p class="endorse-card__status">Endorsement coming soon</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .endorsements__grid {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }
  .endorse-card {
    background: rgba(255, 255, 255, 0.5);
    border: 1.5px dashed var(--driftwood);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    text-align: center;
    min-height: 170px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.4rem;
  }
  .endorse-card__mark {
    font-family: var(--font-display);
    font-size: 2.4rem;
    line-height: 0.6;
    color: var(--salmon-copper);
  }
  .endorse-card__role { font-weight: 600; color: var(--tide-deep); }
  .endorse-card__status {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.7rem;
    color: var(--ink-soft);
  }

  @media (min-width: 620px) {
    .endorsements__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .endorsements__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
