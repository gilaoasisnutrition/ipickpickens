---
// Footer.astro — inverted palette: iron-gall ink ground, parchment text.
const year = 2026;
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="wordmark">BE Canine</p>
        <p class="tagline">
          The canine line of
          <a
            href="https://botanicalenlightenment.com"
            target="_blank"
            rel="noopener"
          >Botanical Enlightenment</a>
        </p>
        <p class="tagline">Premium canine nutrition, made in small batches.</p>
        <p class="contact">
          <a href="mailto:hello@becanine.com">hello@becanine.com</a>
        </p>
      </div>

      <nav class="footer-nav" aria-label="Footer">
        <h3 class="footer-heading">on this page</h3>
        <ul>
          <li><a href="#story">Our Story</a></li>
          <li><a href="#products">The Formulas</a></li>
          <li><a href="#quality">Sourcing &amp; Standards</a></li>
          <li><a href="#signup">The Dispatch</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-legal">
      <p>
        These statements have not been evaluated by the Food and Drug
        Administration. This product is not intended to diagnose, treat, cure,
        or prevent any disease.
      </p>
      <p>
        For dogs only. Not for human consumption. If your dog is pregnant,
        nursing, or receiving veterinary care, consult your veterinarian
        before use.
      </p>
      <p class="copyright">
        &copy; {year} Botanical Enlightenment. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--ink);
    color: var(--parchment);
    padding-block: clamp(3rem, 6vw, 4.5rem) 2rem;
    font-size: var(--text-base);
  }

  .footer a {
    color: var(--gold);
    text-decoration-color: rgba(244, 237, 218, 0.25);
    text-underline-offset: 0.2em;
  }

  .footer a:hover {
    color: var(--parchment);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.1;
    margin: 0 0 0.35rem;
  }

  .tagline {
    color: rgba(244, 237, 218, 0.75);
    margin: 0 0 0.75rem;
    font-style: italic;
  }

  .contact {
    margin: 0;
  }

  .footer-heading {
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: 0.3em;
    text-transform: lowercase;
    color: rgba(244, 237, 218, 0.6);
    margin: 0 0 0.8rem;
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-nav a {
    text-decoration: none;
  }

  .footer-nav a:hover {
    text-decoration: underline;
  }

  .footer-legal {
    margin-top: 2.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(244, 237, 218, 0.25);
    color: rgba(244, 237, 218, 0.62);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .footer-legal p {
    margin: 0 0 0.75em;
    max-width: 60rem;
  }

  .copyright {
    margin-bottom: 0;
    color: rgba(244, 237, 218, 0.5);
  }

  @media (min-width: 44rem) {
    .footer-top {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 3rem;
    }
  }
</style>
