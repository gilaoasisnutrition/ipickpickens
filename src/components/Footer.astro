---
import TideDivider from './TideDivider.astro';
import Triquetra from './Triquetra.astro';

const links = [
  { href: '#top', label: 'Home' },
  { href: '#about', label: 'About' },
  { href: '#leadership', label: 'Leadership' },
  { href: '#platform', label: 'Platform' },
  { href: '#books', label: 'Books' },
  { href: '#events', label: 'Events' },
  { href: '#get-involved', label: 'Get Involved' },
  { href: '#donate', label: 'Donate' },
];

// Social placeholders — replace href="#" with real profile URLs.
const socials = [
  { label: 'Facebook', href: '#', todo: 'facebook-url' },
  { label: 'X', href: '#', todo: 'x-url' },
  { label: 'Instagram', href: '#', todo: 'instagram-url' },
  { label: 'YouTube', href: '#', todo: 'youtube-url' },
];
---

<footer class="footer on-dark" aria-labelledby="footer-heading">
  <TideDivider class="tide-divider--on-dark" />
  <div class="container footer__inner">
    <h2 id="footer-heading" class="visually-hidden">Site footer</h2>

    <div class="footer__brand">
      <Triquetra class="footer__knot" size={32} stroke="var(--gold-bright)" />
      <a class="wordmark" href="#top">
        <span>I&nbsp;Pick</span> <span class="wordmark__p">Pickens</span>
      </a>
      <p class="footer__tagline">C. Michael Pickens for Pacific County Commissioner · 2028</p>
      <ul class="footer__social" aria-label="Social media">
        {socials.map((s) => (
          <li>
            <a href={s.href} data-todo={s.todo} aria-label={s.label}>{s.label}</a>
          </li>
        ))}
      </ul>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>
  </div>

  <!-- Compliance disclaimer box.
       DRAFT — WA PDC (Public Disclosure Commission) disclosure requirements
       MUST be confirmed before launch: exact committee name, "Paid for by"
       formatting, treasurer/address, and any sponsor-ID rules.
       Ref: https://www.pdc.wa.gov/ -->
  <div class="footer__disclaimer">
    <div class="container">
      <p>
        Paid for by <strong>[Committee Name TBD]</strong> — [Address TBD],
        Pacific County, WA.
      </p>
      <p class="footer__fineprint">
        Committee registration, contribution limits, and disclaimer language
        pending confirmation with the Washington State Public Disclosure
        Commission (PDC) before launch. Not authorized by any other committee.
      </p>
    </div>
  </div>

  <div class="footer__meta">
    <div class="container footer__meta-inner">
      <span>© {new Date().getFullYear()} C. Michael Pickens Campaign. All rights reserved.</span>
      <span>IPickPickens.com</span>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--tide-deep); color: var(--fog); }
  .footer .tide-divider-wrap { background: var(--tide-deep); }

  .footer__inner {
    display: grid;
    gap: 2rem;
    padding-block: clamp(2.5rem, 2rem + 2vw, 3.5rem);
  }
  .footer__knot { display: block; margin-bottom: 0.85rem; opacity: 0.7; }
  .footer .wordmark {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    color: var(--fog);
    text-decoration: none;
  }
  .footer .wordmark__p { color: var(--gold-bright); }
  .footer__tagline { margin-top: 0.6rem; color: var(--driftwood); max-width: 40ch; }

  .footer__social {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 1.2rem 0 0;
  }
  .footer__social a {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--fog);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--salmon-copper);
  }
  .footer__social a:hover { color: var(--gold-bright); }

  .footer__nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.6rem 1.5rem;
  }
  .footer__nav a {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--driftwood);
    text-decoration: none;
  }
  .footer__nav a:hover { color: var(--fog); }

  .footer__disclaimer {
    background: var(--cedar);
    color: var(--fog);
    border-top: 3px solid var(--gold);
    padding-block: 1.4rem;
    font-size: 0.9rem;
  }
  .footer__disclaimer strong { color: #fff; }
  .footer__fineprint { margin-top: 0.5rem; font-size: var(--step--1); color: var(--driftwood); }

  .footer__meta {
    background: #0a2226;
    padding-block: 1rem;
  }
  .footer__meta-inner {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.68rem;
    color: var(--driftwood);
  }

  @media (min-width: 780px) {
    .footer__inner { grid-template-columns: 1.3fr 1fr; align-items: start; }
    .footer__nav { grid-template-columns: repeat(2, minmax(0, auto)); justify-content: end; }
  }
</style>
