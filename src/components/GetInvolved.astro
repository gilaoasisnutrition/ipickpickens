---
/**
 * Get Involved — signup form, wired to the Worker at POST /api/signup
 * (worker/index.js), which stores entries in the SIGNUPS KV namespace.
 * Falls back to a normal form POST when JS is unavailable.
 * Turnstile bot check renders only when a site key is set in src/config.ts.
 */
import CelticTexture from './CelticTexture.astro';
import { TURNSTILE_SITE_KEY } from '../config';

const volunteerOptions = [
  'Yard sign',
  'Door knocking',
  'Phone / text banking',
  'Host an event',
  'Donate my time / skills',
  'Just keep me posted',
];
---

<section class="section section--dark on-dark get-involved" id="get-involved" aria-labelledby="get-involved-title">
  <CelticTexture stroke="rgba(216,178,90,0.05)" />
  <div class="container get-involved__grid">
    <div class="get-involved__intro">
      <p class="eyebrow">Join the Campaign</p>
      <h2 class="section-title" id="get-involved-title">It takes a county to win.</h2>
      <p class="lede">
        Add your name, tell us how you'd like to help, and we'll be in touch.
        Every sign, every door, and every conversation moves this forward.
      </p>
      <p class="get-involved__vote">
        Not registered to vote yet — or not sure? Washington makes it easy:
        <a href="https://voter.votewa.gov" target="_blank" rel="noopener noreferrer">check your status at VoteWA.gov</a>.
      </p>
    </div>

    <form class="signup" method="post" action="/api/signup" aria-labelledby="get-involved-title">
      <div class="signup__row">
        <div class="field">
          <label for="signup-name">Name</label>
          <input id="signup-name" name="name" type="text" autocomplete="name" required />
        </div>
        <div class="field">
          <label for="signup-zip">ZIP code</label>
          <input id="signup-zip" name="zip" type="text" inputmode="numeric" autocomplete="postal-code" pattern="[0-9]{5}" />
        </div>
      </div>

      <div class="field">
        <label for="signup-email">Email</label>
        <input id="signup-email" name="email" type="email" autocomplete="email" required />
      </div>

      <fieldset class="field volunteer">
        <legend>How would you like to help?</legend>
        <div class="volunteer__grid">
          {volunteerOptions.map((opt, i) => (
            <label class="checkbox">
              <input type="checkbox" name="help" value={opt} />
              <span>{opt}</span>
            </label>
          ))}
        </div>
      </fieldset>

      {TURNSTILE_SITE_KEY && (
        <div
          class="cf-turnstile"
          data-sitekey={TURNSTILE_SITE_KEY}
          data-theme="dark"
        />
      )}

      <button class="btn btn--primary signup__submit" type="submit">Count Me In</button>
      <p class="signup__status" role="status" aria-live="polite" hidden></p>
      <p class="signup__note">
        We'll never sell or share your information. Unsubscribe anytime.
      </p>
    </form>
  </div>

  {TURNSTILE_SITE_KEY && (
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer />
  )}
</section>

<style>
  .get-involved {
    position: relative;
    overflow: hidden;
  }
  .get-involved > .container {
    position: relative;
    z-index: 1;
  }
  .get-involved__grid {
    display: grid;
    gap: clamp(2rem, 1rem + 4vw, 3.5rem);
    align-items: start;
  }
  .get-involved__vote {
    margin-top: 1.2rem;
    padding: 0.8rem 1rem;
    border-left: 3px solid var(--gold);
    background: var(--tide-deep-2);
    border-radius: var(--radius);
    color: var(--driftwood);
    font-size: var(--step--1);
  }
  .get-involved__vote a { color: var(--gold-bright); font-weight: 600; }
  .signup__status {
    margin: 0;
    font-weight: 600;
    font-size: var(--step--1);
  }
  .signup__status.is-ok { color: var(--gold-bright); }
  .signup__status.is-err { color: #f2a3a3; }
  .signup {
    background: var(--tide-deep-2);
    border: 1px solid rgba(188, 179, 162, 0.22);
    border-radius: var(--radius-lg);
    padding: clamp(1.4rem, 1rem + 2vw, 2rem);
    display: grid;
    gap: 1.1rem;
  }
  .signup__row {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }
  .field { display: grid; gap: 0.4rem; }
  .field label,
  .volunteer legend {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--driftwood);
  }
  .field input[type='text'],
  .field input[type='email'] {
    width: 100%;
    padding: 0.75rem 0.85rem;
    border-radius: var(--radius);
    border: 1px solid var(--driftwood);
    background: var(--fog);
    color: var(--ink);
    font: inherit;
  }
  .field input:focus-visible { outline-color: var(--gold-bright); }

  .volunteer { border: 0; padding: 0; margin: 0; }
  .volunteer legend { padding: 0; margin-bottom: 0.6rem; }
  .volunteer__grid {
    display: grid;
    gap: 0.6rem;
    grid-template-columns: 1fr;
  }
  .checkbox {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--fog);
    font-size: 0.95rem;
    cursor: pointer;
  }
  .checkbox input {
    width: 20px;
    height: 20px;
    accent-color: var(--gold-deep);
    flex: none;
  }
  .signup__submit { justify-self: start; margin-top: 0.3rem; }
  .signup__note { font-size: var(--step--1); color: var(--driftwood); margin: 0; }

  @media (min-width: 560px) {
    .signup__row { grid-template-columns: 1.4fr 0.6fr; }
    .volunteer__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 940px) {
    .get-involved__grid { grid-template-columns: 0.85fr 1.15fr; }
  }
</style>

<script>
  // Progressive enhancement: submit via fetch and show inline status.
  // Without JS the form still POSTs normally; the Worker 303-redirects back
  // with ?signup=thanks, handled below.
  const form = document.querySelector<HTMLFormElement>('.signup');
  const status = document.querySelector<HTMLParagraphElement>('.signup__status');

  const show = (msg: string, ok: boolean) => {
    if (!status) return;
    status.textContent = msg;
    status.classList.toggle('is-ok', ok);
    status.classList.toggle('is-err', !ok);
    status.hidden = false;
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.signup__submit');
    if (btn) btn.disabled = true;
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { accept: 'application/json' },
      });
      const data = await res.json().catch(() => ({ ok: false, error: 'Unexpected response.' }));
      if (data.ok) {
        show("You're in — thank you! We'll be in touch soon.", true);
        form.reset();
      } else {
        show(data.error || 'Something went wrong — please try again.', false);
      }
    } catch {
      show('Network hiccup — please try again in a moment.', false);
    } finally {
      if (btn) btn.disabled = false;
    }
  });

  // No-JS fallback landing: /?signup=thanks#get-involved
  if (new URLSearchParams(location.search).get('signup') === 'thanks') {
    show("You're in — thank you! We'll be in touch soon.", true);
  }
</script>
