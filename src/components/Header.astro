---
// Sticky site header: brand wordmark, anchor nav, cart toggle.
const navLinks = [
  { href: '#story', label: 'Story' },
  { href: '#products', label: 'Collection' },
  { href: '#quality', label: 'Quality' },
  { href: '#signup', label: 'Notify Me' },
];
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#top" aria-label="BE Canine — home">
      <span class="brand-name">BE Canine</span>
      <span class="brand-sub">by botanical enlightenment</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navLinks.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <button
      id="cart-toggle"
      class="cart-toggle"
      aria-label="Open cart"
      aria-haspopup="dialog"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M5.5 8.5h13l-1.2 11a1.6 1.6 0 0 1-1.6 1.4H8.3a1.6 1.6 0 0 1-1.6-1.4l-1.2-11Z" />
        <path d="M8.5 8.5V7a3.5 3.5 0 0 1 7 0v1.5" />
        <path d="M8.5 11.5v1.2" />
        <path d="M15.5 11.5v1.2" />
      </svg>
      <span class="cart-count" data-cart-count>0</span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-h);
    background: rgba(244, 237, 218, 0.92);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--rule);
  }

  .header-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .brand {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    text-decoration: none;
    color: var(--ink);
    margin-right: auto;
  }

  .brand:hover {
    color: var(--ink);
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.45rem;
    letter-spacing: 0.02em;
  }

  .brand-sub {
    font-family: var(--font-display-sc);
    font-size: 0.62rem;
    letter-spacing: 0.28em;
    text-transform: lowercase;
    color: var(--copper);
    margin-top: 0.15rem;
  }

  .site-nav {
    display: none;
  }

  .site-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(1.2rem, 3vw, 2.2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-nav a {
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    letter-spacing: 0.18em;
    text-transform: lowercase;
    color: var(--ink-soft);
    text-decoration: none;
    padding-block: 0.3rem;
    border-bottom: 1px solid transparent;
    transition: color 160ms ease, border-color 160ms ease;
  }

  .site-nav a:hover {
    color: var(--moss-deep);
    border-bottom-color: var(--rule-strong);
  }

  .cart-toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    padding: 0;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 50%;
    color: var(--ink);
    transition: border-color 160ms ease, color 160ms ease, background-color 160ms ease;
  }

  .cart-toggle:hover {
    color: var(--moss-deep);
    border-color: var(--rule-strong);
    background: rgba(63, 82, 49, 0.07);
  }

  .cart-count {
    position: absolute;
    top: -0.35rem;
    right: -0.35rem;
    min-width: 1.15rem;
    height: 1.15rem;
    padding-inline: 0.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--copper);
    color: var(--parchment);
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    line-height: 1;
    border-radius: 999px;
    box-shadow: 0 1px 3px rgba(46, 36, 24, 0.3);
  }

  @media (min-width: 48rem) {
    .site-nav {
      display: block;
    }
  }
</style>
