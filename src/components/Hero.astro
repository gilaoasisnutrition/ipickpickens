---
// Hero: full-width opening plate — wordmark, tagline, CTAs, engraved botanical.
---

<section class="hero" id="top" aria-labelledby="hero-heading">
  <div class="container hero-inner">
    <div class="hero-text" data-reveal>
      <span class="eyebrow">premium canine nutrition</span>
      <h1 id="hero-heading">BE Canine</h1>
      <div class="ornament" role="presentation"><span>❦</span></div>
      <p class="hero-tagline">
        The nutrition your dog deserves — for every walk, every meal, every
        year you share.
      </p>
      <p class="hero-support">
        Seven targeted formulas built from whole-food ingredients by a canine
        nutritionist, made in small batches, and third-party tested for purity
        — every batch, no exceptions.
      </p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href="#products">Shop the Formulas</a>
        <a class="btn btn-outline" href="#story">Why BE Canine</a>
      </div>
    </div>

    <div class="hero-figure" aria-hidden="true">
      <img
        src="/assets/hero-botanical.svg"
        alt=""
        width="520"
        height="420"
        loading="eager"
      />
    </div>
  </div>

  <a class="scroll-cue" href="#products">
    <span aria-hidden="true">↓</span> the formulas
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(88vh - var(--header-h));
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(3rem, 7vw, 5rem) clamp(4rem, 8vw, 6rem);
    overflow: hidden;
  }

  .hero-inner {
    position: relative;
    display: grid;
    align-items: center;
    gap: 2rem;
  }

  .hero-text {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 38rem;
    margin-inline: auto;
  }

  .hero h1 {
    font-size: var(--text-3xl);
    margin-bottom: 0.2em;
  }

  .hero-text .ornament {
    max-width: 16rem;
    margin-inline: auto;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--ink);
    margin-bottom: 0.5em;
  }

  .hero-support {
    font-size: var(--text-base);
    color: var(--ink-soft);
    margin-bottom: 1.8em;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
  }

  /* Engraved plate: faded behind the text on small screens, beside it on wide */
  .hero-figure {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.14;
    pointer-events: none;
  }

  .hero-figure img {
    width: min(32rem, 90%);
    height: auto;
  }

  .scroll-cue {
    align-self: center;
    margin-top: clamp(2rem, 5vw, 3.5rem);
    font-family: var(--font-display-sc);
    font-size: var(--text-sm);
    letter-spacing: 0.24em;
    text-transform: lowercase;
    color: var(--ink-soft);
    text-decoration: none;
  }

  .scroll-cue:hover {
    color: var(--moss-deep);
  }

  @media (min-width: 60rem) {
    .hero-inner {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
      gap: 3rem;
    }

    .hero-text {
      text-align: left;
      margin-inline: 0;
    }

    .hero-text .ornament {
      margin-inline: 0;
    }

    .hero-ctas {
      justify-content: flex-start;
    }

    .hero-figure {
      position: static;
      opacity: 0.85;
    }

    .hero-figure img {
      width: 100%;
      max-width: 32.5rem;
    }
  }
</style>
