---
/**
 * Highlight — "In conversation with Jack Canfield."
 * Feature section for Michael's on-camera interview with Jack Canfield
 * (co-creator of the Chicken Soup for the Soul® series). Links out to the
 * video; real photos supplied by Michael.
 */
import { Image } from 'astro:assets';
import interview from '../assets/photos/canfield-interview.jpg';
import titlecard from '../assets/photos/canfield-titlecard.jpg';
import selfie from '../assets/photos/canfield-selfie.jpg';

const videoUrl = 'https://www.facebook.com/share/v/195kdb9ixZ/';
---

<section class="section section--dark on-dark highlight" id="featured" aria-labelledby="highlight-title">
  <div class="container highlight__grid">
    <div class="highlight__copy">
      <p class="eyebrow">Featured</p>
      <h2 class="section-title" id="highlight-title">In conversation with Jack Canfield</h2>

      <p class="lede">
        Michael sat down with <strong>Jack Canfield</strong> — co-creator of the
        <em>Chicken Soup for the Soul</em>® series and one of America's
        best-known voices on leadership and personal achievement — for a featured
        interview on entrepreneurship, empowerment, and building people up.
      </p>
      <p class="highlight__body">
        It's the message that runs through all of Michael's work: real
        leadership means helping the people around you succeed.
      </p>

      <a class="btn btn--primary" href={videoUrl} target="_blank" rel="noopener noreferrer">
        Watch the Feature
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7 17 17 7M9 7h8v8" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <div class="highlight__media">
      <figure class="highlight__still">
        <Image
          src={interview}
          widths={[640, 1280]}
          sizes="(min-width: 940px) 640px, 92vw"
          format="webp"
          quality={80}
          alt="Michael Pickens and Jack Canfield seated across from each other during the filmed interview"
          loading="lazy"
        />
      </figure>
      <div class="highlight__row">
        <figure class="highlight__still">
          <Image
            src={titlecard}
            widths={[420, 840]}
            sizes="(min-width: 940px) 390px, 56vw"
            format="webp"
            quality={80}
            alt="Interview title card reading Michael Pickens, Chief Empowerment Officer, Botanical Enlightenment"
            loading="lazy"
          />
        </figure>
        <figure class="highlight__still highlight__still--portrait">
          <Image
            src={selfie}
            widths={[260, 520]}
            sizes="(min-width: 940px) 240px, 35vw"
            format="webp"
            quality={80}
            alt="Michael Pickens with Jack Canfield after the interview"
            loading="lazy"
          />
        </figure>
      </div>
    </div>
  </div>
</section>

<style>
  .highlight__grid {
    display: grid;
    gap: clamp(2rem, 1rem + 4vw, 3.5rem);
    align-items: center;
  }
  .highlight__body {
    margin-top: 1rem;
    max-width: 52ch;
    color: var(--driftwood);
  }
  .highlight__copy .btn { margin-top: 1.8rem; }
  .highlight__copy strong { color: var(--fog); }

  .highlight__media {
    display: grid;
    gap: 0.9rem;
  }
  .highlight__still {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(188, 179, 162, 0.28);
    box-shadow: var(--shadow);
    background: var(--tide-deep-2);
  }
  .highlight__still img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .highlight__row {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 0.9rem;
  }
  .highlight__row .highlight__still img { aspect-ratio: 16 / 7; }
  .highlight__still--portrait img { aspect-ratio: auto; height: 100%; }

  @media (min-width: 940px) {
    .highlight__grid { grid-template-columns: 0.9fr 1.1fr; }
  }
</style>
