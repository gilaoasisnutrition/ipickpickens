---
/**
 * Livestream — Michael's daily (weekday) show spotlighting Libertarian
 * candidates nationwide. Pulled out of the About timeline into its own section.
 * data-todo="livestream-url" — wire the Watch button to the real stream/channel.
 */
---

<section class="section section--driftwood live" id="live" aria-labelledby="live-title">
  <div class="container live__grid">
    <div class="live__media">
      <div class="live__frame">
        <img
          src="/assets/about-deeohgee.jpg"
          width="1152"
          height="2048"
          alt="Michael Pickens on the livestream couch with his dog Dee Oh Gee, who is wearing a headset"
          loading="lazy"
        />
        <span class="live__badge"><span class="live__dot" aria-hidden="true"></span> Live · Weekdays</span>
      </div>
    </div>

    <div class="live__copy">
      <p class="eyebrow">On Air Every Weekday</p>
      <h2 class="section-title" id="live-title">Showcasing liberty's next leaders — daily.</h2>
      <!-- DRAFT COPY — verify with candidate -->
      <p class="lede">
        Every weekday, Michael goes live to spotlight Libertarian candidates from
        across the country — real conversations about running, winning, and
        leading. It's the leader-of-leaders philosophy in action, five days a
        week. Co-host Dee Oh Gee keeps the interviews honest.
      </p>
      <a class="btn btn--primary live__cta" href="#" data-todo="livestream-url">Watch the Livestream</a>
    </div>
  </div>
</section>

<style>
  .live__grid {
    display: grid;
    gap: clamp(2rem, 1rem + 4vw, 3.5rem);
    align-items: center;
  }
  .live__media { justify-self: center; width: 100%; max-width: 340px; }
  .live__frame {
    position: relative;
    border-radius: var(--radius-lg);
  }
  .live__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    transform: translate(14px, 14px);
    border: 3px solid var(--gold);
    border-radius: var(--radius-lg);
  }
  .live__frame img {
    position: relative;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: 50% 30%;
    border-radius: var(--radius-lg);
    border: 1px solid var(--driftwood);
    box-shadow: var(--shadow);
  }
  .live__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--tide-deep);
    color: var(--fog);
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    border: 1px solid rgba(188, 179, 162, 0.35);
  }
  .live__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--gold-bright);
    animation: live-pulse 1.8s ease-in-out infinite;
  }
  @keyframes live-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }
  .live__cta { margin-top: 1.8rem; }

  @media (min-width: 860px) {
    .live__grid { grid-template-columns: 0.8fr 1.2fr; }
    .live__media { justify-self: start; }
  }
</style>
