---
/**
 * Platform — 5–6 county-scoped issue cards. Drafted as starting points and
 * flagged for candidate review. Numbered like a nautical chart legend.
 */
const issues = [
  {
    title: 'Budget Transparency & Accountability',
    body: 'Every county dollar should be traceable and public. Plain-language budgets, open contracts, and a commission that answers to residents for how their money is spent.',
  },
  {
    title: 'Property Rights & Sane Land-Use',
    body: 'Permitting that respects the people who own the land. Predictable rules, reasonable timelines, and an end to red tape that punishes families and small builders.',
  },
  {
    title: 'Working Waterfronts',
    body: 'Fishing, shellfish, and timber built this county. County government should defend these industries and the working families who depend on them — not regulate them out of existence.',
  },
  {
    title: 'Beach Access & Tourism',
    body: 'Keep our beaches open, our approaches maintained, and our tourism economy thriving — while protecting the coast that draws visitors here in the first place.',
  },
  {
    title: 'Public Safety & Emergency Readiness',
    body: 'A coast that is ready for the storm, the tsunami, and the everyday emergency. Reliable response, sober planning, and support for the people who keep us safe.',
  },
  {
    title: 'Answerable to Residents, Not Olympia',
    body: 'Decisions about Pacific County should be made in Pacific County. A commissioner who pushes back on state overreach and keeps local government local.',
  },
];
---

<section class="section section--dark on-dark platform" id="platform" aria-labelledby="platform-title">
  <div class="container">
    <p class="eyebrow">Where I Stand</p>
    <h2 class="section-title" id="platform-title">A Platform Built for Pacific County</h2>
    <p class="lede">
      Six commitments, all local. These are starting points — shaped by
      conversations with residents up and down the county.
    </p>

    <!-- DRAFT COPY — verify with candidate. Positions are drafts pending review. -->
    <ul class="platform__grid">
      {issues.map((issue, i) => (
        <li class="issue-card">
          <span class="issue-card__num">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="issue-card__title">{issue.title}</h3>
          <p class="issue-card__body">{issue.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .platform__grid {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1fr;
  }
  .issue-card {
    position: relative;
    background: var(--tide-deep-2);
    border: 1px solid rgba(188, 179, 162, 0.22);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.5rem;
    overflow: hidden;
  }
  .issue-card::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--gold);
  }
  .issue-card__num {
    font-family: var(--font-util);
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    color: var(--salmon-copper);
  }
  .issue-card__title {
    font-size: var(--step-1);
    margin: 0.5rem 0 0.5rem;
    color: var(--fog);
  }
  .issue-card__body { color: var(--driftwood); margin: 0; }

  @media (min-width: 640px) {
    .platform__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .platform__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
