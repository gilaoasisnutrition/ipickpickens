---
/**
 * Guiding Principles — four icon cards (mirrors the reference layout).
 * Coastal-grounded, one-line blurbs. Icons are inline SVG filled with salmon.
 */
const principles = [
  {
    title: 'Individual Liberty',
    body: 'The people of Pacific County know how to run their own lives, businesses, and land better than any distant bureaucracy.',
    icon: 'compass',
  },
  {
    title: 'Local Control',
    body: 'Decisions about our bay, beaches, and timberlands belong to the people who live here — not to Olympia.',
    icon: 'anchor',
  },
  {
    title: 'Limited Government',
    body: 'A county that spends carefully, permits sensibly, and stays out of the way of honest, hard-working families.',
    icon: 'wave',
  },
  {
    title: 'Personal Responsibility',
    body: 'Neighbors looking out for neighbors built this coast. Good government protects that spirit instead of replacing it.',
    icon: 'buoy',
  },
];
---

<section class="section principles" aria-labelledby="principles-title">
  <div class="container">
    <p class="eyebrow">What I Stand For</p>
    <h2 class="section-title" id="principles-title">Guiding Principles</h2>

    <ul class="principles__grid">
      {principles.map((p) => (
        <li class="principle-card">
          <span class="principle-card__icon" aria-hidden="true">
            {p.icon === 'compass' && (
              <svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="19" fill="none" stroke="currentColor" stroke-width="2.4"/><path d="M24 24 30 16 26 26 16 32 22 22Z" fill="currentColor"/><circle cx="24" cy="24" r="2.4" fill="var(--fog)"/></svg>
            )}
            {p.icon === 'anchor' && (
              <svg viewBox="0 0 48 48"><circle cx="24" cy="11" r="4" fill="none" stroke="currentColor" stroke-width="2.4"/><path d="M24 15v24M14 26h20M12 33c3 6 9 8 12 8s9-2 12-8" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
            )}
            {p.icon === 'wave' && (
              <svg viewBox="0 0 48 48"><path d="M6 20c4-5 8-5 12 0s8 5 12 0 8-5 12 0M6 30c4-5 8-5 12 0s8 5 12 0 8-5 12 0" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round"/></svg>
            )}
            {p.icon === 'buoy' && (
              <svg viewBox="0 0 48 48"><circle cx="24" cy="24" r="14" fill="none" stroke="currentColor" stroke-width="2.4"/><path d="M24 10v28M10 24h28" stroke="currentColor" stroke-width="2.4"/><circle cx="24" cy="24" r="4.5" fill="currentColor"/></svg>
            )}
          </span>
          <h3 class="principle-card__title">{p.title}</h3>
          <p class="principle-card__body">{p.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .principles__grid {
    list-style: none;
    padding: 0;
    margin: 2.5rem 0 0;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: 1fr;
  }
  .principle-card {
    background: #fff;
    border: 1px solid var(--driftwood);
    border-top: 4px solid var(--cranberry);
    border-radius: var(--radius-lg);
    padding: 1.6rem 1.5rem 1.7rem;
    box-shadow: 0 10px 30px -24px rgba(13, 43, 48, 0.6);
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .principle-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -26px rgba(13, 43, 48, 0.75);
  }
  .principle-card__icon {
    display: inline-flex;
    width: 54px;
    height: 54px;
    color: var(--salmon-copper);
  }
  .principle-card__icon svg { width: 100%; height: 100%; }
  .principle-card__title {
    font-size: var(--step-1);
    margin: 0.9rem 0 0.4rem;
  }
  .principle-card__body {
    color: var(--ink-soft);
    font-size: var(--step-0);
    margin: 0;
  }

  @media (min-width: 620px) {
    .principles__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1000px) {
    .principles__grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>
