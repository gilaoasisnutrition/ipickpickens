---
/**
 * Pacific County Roots — photo-led strip celebrating place. Carries the local
 * identity of the site. Short, affectionate copy per tile.
 */
const tiles = [
  {
    img: '/assets/roots-oysters.svg',
    alt: 'Willapa Bay oyster beds exposed at low tide near South Bend',
    kicker: 'South Bend',
    title: 'Oyster Capital of the World',
    body: 'Willapa Bay grows some of the finest oysters on earth — and the families who tend those beds are the backbone of this county.',
  },
  {
    img: '/assets/roots-razor-clams.svg',
    alt: 'Razor clam diggers on the Long Beach Peninsula at dawn',
    kicker: 'Long Beach Peninsula',
    title: "The World's Longest Drivable Beach",
    body: 'Razor clams at dawn, kites in the afternoon, and 28 miles of sand you can drive. This is where the coast comes to play.',
  },
  {
    img: '/assets/roots-ilwaco-fleet.svg',
    alt: 'Commercial fishing boats moored at Ilwaco harbor',
    kicker: 'Ilwaco',
    title: 'A Working Fleet',
    body: 'The boats at Ilwaco harbor still go out before sunrise — a working way of life that shaped the people who live here.',
  },
  {
    img: '/assets/roots-cranberry-bog.svg',
    alt: 'Flooded cranberry bog at harvest on the Long Beach Peninsula',
    kicker: 'Cranberry Country',
    title: 'A Century of Bogs',
    body: 'Pacific County cranberries have been harvested here for generations — a quiet, hard-won agricultural heritage worth protecting.',
  },
  {
    img: '/assets/roots-cedar-grove.svg',
    alt: 'Old-growth cedar grove on Long Island in Willapa Bay',
    kicker: 'Willapa NWR',
    title: 'Ancient Cedars',
    body: 'The old-growth cedar grove on Long Island has stood for a thousand years — a reminder of what stewardship really means.',
  },
];
---

<section class="section roots" id="roots" aria-labelledby="roots-title">
  <div class="container">
    <p class="eyebrow">Pacific County Roots</p>
    <h2 class="section-title" id="roots-title">This is home. This is what we're fighting for.</h2>
    <p class="lede">
      From the oyster beds of Willapa Bay to the ancient cedars of Long Island —
      a county worth showing up for.
    </p>
  </div>

  <div class="roots__scroller">
    <ul class="roots__strip">
      {tiles.map((t) => (
        <li class="roots-tile">
          <img src={t.img} width="1200" height="800" alt={t.alt} loading="lazy" />
          <div class="roots-tile__overlay">
            <span class="roots-tile__kicker">{t.kicker}</span>
            <h3 class="roots-tile__title">{t.title}</h3>
            <p class="roots-tile__body">{t.body}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .roots__scroller {
    margin-top: 2.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding-inline: var(--gutter);
    padding-bottom: 0.75rem;
  }
  .roots__strip {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: min(85%, 380px);
    gap: 1.1rem;
    width: max-content;
    max-width: none;
    margin-inline: auto;
  }
  .roots-tile {
    position: relative;
    scroll-snap-align: start;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow);
    aspect-ratio: 3 / 4;
  }
  .roots-tile img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .roots-tile__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.4rem;
    color: var(--fog);
    background: linear-gradient(
      to top,
      rgba(13, 43, 48, 0.92) 0%,
      rgba(13, 43, 48, 0.55) 45%,
      rgba(13, 43, 48, 0.05) 100%
    );
  }
  .roots-tile__kicker {
    font-family: var(--font-util);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--salmon-copper);
  }
  .roots-tile__title { font-size: var(--step-1); margin: 0.3rem 0 0.5rem; }
  .roots-tile__body { font-size: 0.95rem; color: var(--driftwood); margin: 0; }

  @media (min-width: 1000px) {
    .roots__scroller { overflow-x: visible; }
    .roots__strip {
      grid-auto-flow: row;
      grid-template-columns: repeat(6, 1fr);
      grid-auto-columns: auto;
      width: auto;
      max-width: var(--container);
    }
    /* First tile spans wider for an editorial rhythm */
    .roots-tile:nth-child(1) { grid-column: span 3; }
    .roots-tile:nth-child(2) { grid-column: span 3; }
    .roots-tile:nth-child(3) { grid-column: span 2; }
    .roots-tile:nth-child(4) { grid-column: span 2; }
    .roots-tile:nth-child(5) { grid-column: span 2; }
  }
</style>
