---
/**
 * TideDivider — a single thin depth-contour line reused between sections as the
 * consistent "tide line" divider (replaces the reference site's zigzag).
 */
export interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class={`tide-divider-wrap ${className}`} role="presentation">
  <svg
    class="tide-divider"
    viewBox="0 0 1200 24"
    preserveAspectRatio="none"
    aria-hidden="true"
    focusable="false"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M0 14 C 120 4, 240 20, 360 12 S 600 2, 720 13 S 960 22, 1080 11 1200 14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    />
    <path
      d="M0 18 C 120 9, 240 24, 360 16 S 600 7, 720 17 S 960 26, 1080 15 1200 18"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      opacity="0.5"
      stroke-dasharray="2 8"
    />
  </svg>
</div>

<style>
  .tide-divider-wrap {
    line-height: 0;
    background: inherit;
  }
</style>
