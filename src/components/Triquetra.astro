---
/**
 * Triquetra (trinity knot) — a tasteful nod to Celtic/Irish heritage.
 * Three interlocking vesicae with an optional binding ring. Decorative only.
 */
export interface Props {
  class?: string;
  stroke?: string;
  size?: number;
  withCircle?: boolean;
}
const {
  class: className = '',
  stroke = 'currentColor',
  size = 48,
  withCircle = true,
} = Astro.props;
---

<svg
  class={`triquetra ${className}`}
  width={size}
  height={size}
  viewBox="0 0 100 100"
  aria-hidden="true"
  focusable="false"
  xmlns="http://www.w3.org/2000/svg"
>
  <g fill="none" stroke={stroke} stroke-width="3.4" stroke-linejoin="round">
    <!-- Each petal is a vesica radiating from the centre (50,50); rotating three
         copies 120° apart forms the interlaced trinity knot. -->
    <path d="M50 50 A 24 24 0 0 1 50 12 A 24 24 0 0 1 50 50 Z" transform="rotate(0 50 50)" />
    <path d="M50 50 A 24 24 0 0 1 50 12 A 24 24 0 0 1 50 50 Z" transform="rotate(120 50 50)" />
    <path d="M50 50 A 24 24 0 0 1 50 12 A 24 24 0 0 1 50 50 Z" transform="rotate(240 50 50)" />
    {withCircle && <circle cx="50" cy="50" r="30" stroke-width="2.4" />}
  </g>
</svg>
