---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChartTexture from '../components/ChartTexture.astro';

// Served by Cloudflare Workers static assets for any unknown path
// (wrangler.jsonc: assets.not_found_handling = "404-page").
---

<BaseLayout title="Off the Chart — C. Michael Pickens">
  <main id="main" class="lost on-dark">
    <ChartTexture />
    <div class="lost__inner">
      <p class="eyebrow">404 · Uncharted Water</p>
      <h1 class="lost__title">You've drifted off the chart.</h1>
      <p class="lost__body">
        This page isn't on our map — maybe the tide took it. Head back to shore
        and we'll get you where you're going.
      </p>
      <div class="lost__cta">
        <a class="btn btn--primary" href="/">Back to Home Port</a>
        <a class="btn btn--outline" href="/#contact">Get in Touch</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .lost {
    position: relative;
    min-height: 100vh;
    display: grid;
    place-items: center;
    background: var(--tide-deep);
    color: var(--fog);
    overflow: hidden;
    padding: var(--gutter);
  }
  .lost__inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 34rem;
  }
  .lost__title {
    font-size: var(--step-3);
    margin-top: 0.7rem;
  }
  .lost__body {
    margin-top: 1rem;
    color: var(--driftwood);
    font-size: var(--step-1);
  }
  .lost__cta {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }
</style>
