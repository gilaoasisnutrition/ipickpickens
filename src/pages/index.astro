---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import BrandStory from '../components/BrandStory.astro';
import ProductGrid from '../components/ProductGrid.astro';
import Quality from '../components/Quality.astro';
import EmailCapture from '../components/EmailCapture.astro';
import Footer from '../components/Footer.astro';
import CartDrawer from '../components/CartDrawer.astro';
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <BrandStory />
    <ProductGrid />
    <Quality />
    <EmailCapture />
  </main>
  <Footer />
  <CartDrawer />

  <script>
    import '../scripts/cart.js';
  </script>
</BaseLayout>
