---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Ticker from '../components/Ticker.astro';
import Hero from '../components/Hero.astro';
import Principles from '../components/Principles.astro';
import About from '../components/About.astro';
import Highlight from '../components/Highlight.astro';
import Livestream from '../components/Livestream.astro';
import Books from '../components/Books.astro';
import SevenPrinciples from '../components/SevenPrinciples.astro';
import Roots from '../components/Roots.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import TideDivider from '../components/TideDivider.astro';
import { SITE_URL, SOCIALS, BOOKS, LLA_URL } from '../config';

// Structured data: person + published books. Helps search engines build a
// knowledge panel for "C. Michael Pickens".
const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${SITE_URL}/#person`,
      name: 'C. Michael Pickens',
      alternateName: 'CMPickens',
      url: SITE_URL,
      image: `${SITE_URL}/assets/og-image.png`,
      description:
        'Author, leadership educator, Chair of the Libertarian Party of Washington, and founder of the Libertarian Leadership Academy.',
      affiliation: [
        {
          '@type': 'Organization',
          name: 'Libertarian Party of Washington',
          url: 'https://lpwa.org',
        },
        {
          '@type': 'Organization',
          name: 'Libertarian Leadership Academy',
          url: LLA_URL,
        },
      ],
      sameAs: [
        SOCIALS.facebook,
        SOCIALS.x,
        SOCIALS.instagram,
        SOCIALS.youtube,
        LLA_URL,
      ],
    },
    {
      '@type': 'Book',
      name: 'Libertarian Leadership: Planting the Seed for a Libertarian Future',
      author: { '@id': `${SITE_URL}/#person` },
      datePublished: '2012',
      url: BOOKS.libertarianLeadership,
    },
    {
      '@type': 'Book',
      name: 'The Liberated Mind: Rewire Your Mind. Reclaim Your Power. Rewrite Your Life.',
      author: { '@id': `${SITE_URL}/#person` },
      datePublished: '2025',
      url: BOOKS.liberatedMind,
    },
  ],
};
---

<BaseLayout>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Nav />
  <Ticker />
  <main id="main">
    <Hero />
    <Principles />
    <TideDivider />
    <About />
    <Highlight />
    <Livestream />
    <Books />
    <TideDivider />
    <SevenPrinciples />
    <Roots />
    <TideDivider />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
