{
  // Cloudflare Workers static-assets deployment for IPickPickens.com.
  // The site is a fully static Astro build; Workers serves ./dist directly.
  // Docs: https://developers.cloudflare.com/workers/static-assets/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ipickpickens",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist"
  }
}
